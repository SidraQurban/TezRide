{
  "expo": {
    "name": "TezRide",
    "slug": "TezRide",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/applogo.jpeg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logoo.png",
      "resizeMode": "contain",
      "backgroundColor": "#FF5C00"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "package": "com.tezride.customer",
      "adaptiveIcon": {
        "backgroundColor": "#FF5C00",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/notification_icon.png"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "INTERNET",
        "ACCESS_NETWORK_STATE",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyCIbaIdCvCWhGMU8ZvtxDF2DUMIkjYylmU"
        }
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-font",
      "expo-localization",
      "expo-av",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification_icon.png",
          "color": "#FF5C00",
          "defaultChannel": "ride-requests",
          "androidMode": "default",
          "androidCollapsedTitle": "TezRide",
          "sounds": [
            "./assets/notification_alert.mp3",
            "./assets/completed_ride_alert.mp3"
          ]
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "3757b012-d00a-4c03-9e38-189c26489153"
      }
    }
  }
}